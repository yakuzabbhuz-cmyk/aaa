{
  "name": "@dl-chat/mobile",
  "version": "1.0.0",
  "description": "DL Chat Mobile App - React Native + Expo",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:apk": "eas build --platform android --profile apk --non-interactive",
    "build:aab": "eas build --platform android --profile production --non-interactive",
    "build:ios": "eas build --platform ios --profile production --non-interactive",
    "build:preview": "eas build --profile preview",
    "lint": "expo lint"
  },
  "dependencies": {
    "expo": "~51.0.0",
    "expo-router": "~3.5.0",
    "expo-status-bar": "~1.12.1",
    "expo-splash-screen": "~0.27.0",
    "expo-font": "~12.0.0",
    "expo-constants": "~16.0.0",
    "expo-notifications": "~0.28.0",
    "expo-camera": "~15.0.0",
    "expo-av": "~14.0.0",
    "expo-document-picker": "~12.0.0",
    "expo-image-picker": "~15.0.0",
    "expo-local-authentication": "~14.0.0",
    "expo-secure-store": "~13.0.0",
    "expo-file-system": "~17.0.0",
    "expo-image": "~1.12.0",
    "expo-blur": "~13.0.0",
    "expo-haptics": "~13.0.0",
    "react": "18.2.0",
    "react-native": "0.74.1",
    "react-native-reanimated": "~3.10.0",
    "react-native-gesture-handler": "~2.16.0",
    "react-native-screens": "3.31.1",

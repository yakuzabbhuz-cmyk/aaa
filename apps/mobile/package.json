    "@expo/vector-icons": "^14.0.0",
    "nativewind": "^4.0.1",
    "tailwindcss": "^3.4.0",
    "zod": "^3.23.0",
    "react-native-webrtc": "^118.0.0",
    "dayjs": "^1.11.0",
    "react-native-country-picker-modal": "^2.0.0",
    "react-native-svg": "15.2.0",
    "react-native-audio-waveform": "^1.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.2.45",
    "@types/react-native": "^0.73.0",

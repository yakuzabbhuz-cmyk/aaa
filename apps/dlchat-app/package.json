{
  "name": "dl-chat-app",
  "version": "1.0.0",
  "description": "DL Chat - Real-time messaging app by Death Legion Team",
  "homepage": "https://dl-chat-download.pages.dev",
  "author": {
    "name": "Death Legion Team",
    "email": "admin@death-legion.com"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "electron .",
    "dist:win": "electron-builder --win --x64",
    "dist:linux": "electron-builder --linux --x64",
    "dist:all": "electron-builder --win --linux --x64"
  },
  "build": {
    "appId": "com.deathlegion.dlchat",
    "productName": "DL Chat",
    "copyright": "Copyright 2025 Death Legion Team",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "zip", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico",
      "publisherName": "Death Legion Team"
    },
    "linux": {
      "target": [
        { "target": "deb", "arch": ["x64"] },
        { "target": "zip", "arch": ["x64"] }
      ],
      "icon": "assets/icon.png",
      "category": "Network",
      "description": "DL Chat - Real-time messaging",
      "maintainer": "Death Legion Team <admin@death-legion.com>"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DL Chat"
    },
    "deb": {
      "depends": ["libgtk-3-0", "libnotify4", "libxss1", "libxtst6", "xdg-utils", "libatspi2.0-0", "libuuid1", "libsecret-1-0"]
    }
  },
  "dependencies": {
    "electron-updater": "^6.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "vite": "^5.0.0"
  }
}
